<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GeoTaskAIReminder" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:colorAccent">@color/action_primary</item>
        <item name="colorPrimary">@color/action_primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/action_accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="materialButtonStyle">@style/Widget.GeoTask.Button</item>
        <item name="textInputStyle">@style/Widget.GeoTask.TextInputLayout</item>
        <item name="chipStyle">@style/Widget.GeoTask.Chip</item>
    </style>

    <style name="Widget.GeoTask.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.GeoTask.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxStrokeColor">@color/action_primary</item>
        <item name="hintTextColor">@color/action_primary</item>
    </style>

    <style name="Widget.GeoTask.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">8dp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>
